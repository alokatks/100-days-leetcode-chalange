92. Reverse Linked List II

  apporach : break the linkedlist into three part and than reverse the middle part and than merge them agaain

    code:class Solution {
    public static ListNode reverse(ListNode head2) {
        ListNode curr = head2;
        ListNode fwr = null;
        ListNode prev = null;
        while (curr != null) {
            fwr = curr.next;
            curr.next = prev;
            prev = curr;
            curr = fwr;
        }
        return prev;
    }

    public ListNode reverseBetween(ListNode head, int left, int right) {
        if (head == null || left == right) return head;

        // Dummy node handles left = 1 edge case perfectly
        ListNode dummy = new ListNode(0);
        dummy.next = head;
        ListNode temp = dummy;

        // Move temp to the node right BEFORE 'left'
        for (int i = 0; i < left - 1; i++) {
            temp = temp.next;
        } 

        ListNode head2 = temp.next;
        temp.next = null; // Disconnect left side

        // Move temp2 to the 'right' node
        ListNode temp2 = head2;
        for (int i = 0; i < right - left; i++) {
            temp2 = temp2.next;
        }

        ListNode head3 = temp2.next;
        temp2.next = null; // Disconnect right side

        // Reverse the middle segment
        ListNode reversedHead = reverse(head2);

        // Stitch everything back together
        temp.next = reversedHead;
        head2.next = head3; // head2 is now the tail of the reversed part

        return dummy.next;
    }
}
