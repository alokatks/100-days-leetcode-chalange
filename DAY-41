Maximum Total Subarray Value I

CODE: class Solution {
    public long maxTotalValue(int[] nums, int k) {
        int max=0;
        int min=Integer.MAX_VALUE;
        for(int num:nums){
            max = Math.max(max, num);
            min=Math.min(min,num);
        }
        return (long) k*(max-min);
    }
}
